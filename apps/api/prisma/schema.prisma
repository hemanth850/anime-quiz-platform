generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
}

enum Era {
  ERA_90S
  ERA_2000S
  ERA_2010S
  ERA_2020S
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MatchStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum MatchMode {
  CASUAL
  RANKED
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  username       String             @unique
  passwordHash   String
  role           Role               @default(PLAYER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  refreshTokens  RefreshToken[]
  createdQuestions Question[]       @relation("QuestionCreator")
  matchParticipants MatchParticipant[]
  seasonRatings  UserSeasonRating[]
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Question {
  id          String      @id @default(uuid())
  prompt      String
  options     Json
  answerIndex Int
  genre       String
  studio      String
  era         Era
  difficulty  Difficulty
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById String?
  createdBy   User?       @relation("QuestionCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model Match {
  id                 String             @id @default(uuid())
  roomCode           String
  mode               MatchMode          @default(CASUAL)
  genre              String?
  studio             String?
  era                Era?
  questionCount      Int
  timePerQuestionSec Int
  status             MatchStatus        @default(FINISHED)
  startedAt          DateTime           @default(now())
  finishedAt         DateTime?
  seasonId           String?
  season             Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  participants       MatchParticipant[]

  @@index([startedAt])
  @@index([seasonId])
}

model MatchParticipant {
  id          String   @id @default(uuid())
  matchId     String
  userId      String?
  displayName String
  score       Int
  rank        Int
  connected   Boolean
  ratingBefore Int?
  ratingAfter  Int?
  ratingDelta  Int?
  createdAt   DateTime @default(now())

  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@index([userId])
}

model Season {
  id          String            @id @default(uuid())
  code        String            @unique
  name        String
  startsAt    DateTime
  endsAt      DateTime?
  isActive    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  matches     Match[]
  userRatings UserSeasonRating[]

  @@index([isActive])
}

model UserSeasonRating {
  id          String   @id @default(uuid())
  userId      String
  seasonId    String
  rating      Int      @default(1200)
  wins        Int      @default(0)
  losses      Int      @default(0)
  draws       Int      @default(0)
  matches     Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  season      Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, rating])
}
